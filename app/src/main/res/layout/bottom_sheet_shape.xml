<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/color_background"
    android:orientation="vertical"
    android:paddingBottom="32dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="20dp"
        android:text="Chọn Shape Kính"
        android:textColor="@color/color_text_primary"
        android:textSize="16sp"
        android:textStyle="bold" />

    <View
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:background="@color/color_field_border" />

    <TextView
        android:id="@+id/itemShapeTron"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:background="?attr/selectableItemBackground"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:text="Tròn"
        android:textColor="@color/color_text_primary"
        android:textSize="15sp" />

    <TextView
        android:id="@+id/itemShapeOval"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:background="?attr/selectableItemBackground"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:text="Oval"
        android:textColor="@color/color_text_primary"
        android:textSize="15sp" />

    <TextView
        android:id="@+id/itemShapeMatMeo"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:background="?attr/selectableItemBackground"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:text="Mắt Mèo"
        android:textColor="@color/color_text_primary"
        android:textSize="15sp" />

    <TextView
        android:id="@+id/itemShapeVuong"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:background="?attr/selectableItemBackground"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:text="Vuông"
        android:textColor="@color/color_text_primary"
        android:textSize="15sp" />

    <View
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:background="@color/color_field_border" />

    <TextView
        android:id="@+id/itemShapeAll"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:background="?attr/selectableItemBackground"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:text="Tất cả shape"
        android:textColor="@color/color_text_secondary"
        android:textSize="15sp" />

</LinearLayout>
