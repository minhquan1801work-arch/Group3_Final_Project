<?xml version="1.0" encoding="utf-8"?>
<!-- LA.Blog1/2/3 (Figma) — trang bài viết blog dùng chung.
     Cấu trúc: header Quay lại → hero banner → nội dung động (heading/đoạn/ảnh)
     → sản phẩm gợi ý → bài viết liên quan → footer liên hệ. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:orientation="vertical">

    <!-- Header: < Quay lại -->
    <LinearLayout
        android:id="@+id/btnBack"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="?attr/selectableItemBackground"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="12dp">

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:contentDescription="@null"
            android:rotation="180"
            android:src="@drawable/ic_chevron_right"
            app:tint="@color/color_text_primary" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:text="Quay lại"
            android:textColor="@color/color_text_primary"
            android:textSize="14sp" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Hero banner -->
            <ImageView
                android:id="@+id/imgHero"
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:background="@drawable/bg_product_placeholder"
                android:contentDescription="@null"
                android:scaleType="centerCrop" />

            <!-- Nội dung bài viết (heading + đoạn + ảnh) — bơm động từ Java -->
            <LinearLayout
                android:id="@+id/llContent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="16dp"
                android:paddingTop="16dp" />

            <!-- Sản phẩm gợi ý -->
            <TextView
                android:id="@+id/tvProductsTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:paddingHorizontal="16dp"
                android:textColor="@color/color_text_primary"
                android:textSize="14sp"
                android:textStyle="bold"
                tools:text="TIÊU ĐIỂM SẢN PHẨM" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvBlogProducts"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:clipToPadding="false"
                android:orientation="horizontal"
                android:paddingHorizontal="12dp"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />

            <!-- Bài viết liên quan -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:paddingHorizontal="16dp"
                android:text="BÀI VIẾT LIÊN QUAN"
                android:textColor="@color/color_text_primary"
                android:textSize="14sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp">

                <LinearLayout
                    android:id="@+id/relatedCard1"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:layout_weight="1"
                    android:background="?attr/selectableItemBackground"
                    android:orientation="vertical">

                    <ImageView
                        android:id="@+id/imgRelated1"
                        android:layout_width="match_parent"
                        android:layout_height="90dp"
                        android:background="@drawable/bg_product_placeholder"
                        android:contentDescription="@null"
                        android:scaleType="centerCrop" />

                    <TextView
                        android:id="@+id/tvRelated1"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:ellipsize="end"
                        android:gravity="center"
                        android:maxLines="1"
                        android:textColor="@color/color_text_primary"
                        android:textSize="12sp"
                        tools:text="Gọng Kính Hot Trend 2026" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/relatedCard2"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:background="?attr/selectableItemBackground"
                    android:orientation="vertical">

                    <ImageView
                        android:id="@+id/imgRelated2"
                        android:layout_width="match_parent"
                        android:layout_height="90dp"
                        android:background="@drawable/bg_product_placeholder"
                        android:contentDescription="@null"
                        android:scaleType="centerCrop" />

                    <TextView
                        android:id="@+id/tvRelated2"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:ellipsize="end"
                        android:gravity="center"
                        android:maxLines="1"
                        android:textColor="@color/color_text_primary"
                        android:textSize="12sp"
                        tools:text="Bí kíp chọn kính mát an toàn" />
                </LinearLayout>
            </LinearLayout>

            <!-- Footer liên hệ (Figma: email / hotline / giờ mở cửa / About Contact Policy) -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="24dp"
                android:background="@color/color_divider" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:fontFamily="serif"
                android:gravity="center"
                android:text="support@glassity.com"
                android:textColor="@color/color_text_secondary"
                android:textSize="12sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:fontFamily="serif"
                android:gravity="center"
                android:text="+8386 123 789"
                android:textColor="@color/color_text_secondary"
                android:textSize="12sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:fontFamily="serif"
                android:gravity="center"
                android:text="08:00 - 22:00 · Mỗi ngày"
                android:textColor="@color/color_text_secondary"
                android:textSize="12sp" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="14dp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/footerAbout"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="?attr/selectableItemBackground"
                    android:fontFamily="serif"
                    android:padding="8dp"
                    android:text="About"
                    android:textColor="@color/color_text_primary"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/footerContact"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="16dp"
                    android:background="?attr/selectableItemBackground"
                    android:fontFamily="serif"
                    android:padding="8dp"
                    android:text="Contact"
                    android:textColor="@color/color_text_primary"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/footerPolicy"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="?attr/selectableItemBackground"
                    android:fontFamily="serif"
                    android:padding="8dp"
                    android:text="Policy"
                    android:textColor="@color/color_text_primary"
                    android:textSize="13sp" />
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:fontFamily="serif"
                android:gravity="center"
                android:paddingBottom="20dp"
                android:text="Glassity© Bản quyền được bảo hộ."
                android:textColor="@color/color_hint"
                android:textSize="11sp" />
        </LinearLayout>
    </ScrollView>

</LinearLayout>
