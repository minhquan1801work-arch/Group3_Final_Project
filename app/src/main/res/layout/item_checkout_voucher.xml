<?xml version="1.0" encoding="utf-8"?>
<!-- Item voucher trong màn chọn mã giảm giá (LA.Voucher3) — icon | info | radio -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="?attr/selectableItemBackground"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingVertical="12dp">

        <!-- Icon loại voucher (ship/discount) -->
        <FrameLayout
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="#B05A4A">

            <ImageView
                android:id="@+id/ivIcon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:contentDescription="@null"
                android:src="@drawable/ic_voucher_discount"
                app:tint="@color/white"
                xmlns:app="http://schemas.android.com/apk/res-auto" />
        </FrameLayout>

        <!-- Thông tin mã -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="12dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/color_text_primary"
                android:textSize="13sp"
                android:textStyle="bold"
                tools:text="Miễn phí vận chuyển toàn quốc" />

            <TextView
                android:id="@+id/tvMinOrder"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textColor="@color/color_text_secondary"
                android:textSize="12sp"
                tools:text="Đơn tối thiểu 399Kđ" />

            <TextView
                android:id="@+id/tvFooter"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textSize="11sp"
                tools:text="Còn 3 ngày | Điều kiện áp dụng" />
        </LinearLayout>

        <!-- Radio chọn -->
        <RadioButton
            android:id="@+id/rbVoucher"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:buttonTint="@color/color_btn_black"
            android:clickable="false"
            android:focusable="false" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/color_divider" />
</LinearLayout>
