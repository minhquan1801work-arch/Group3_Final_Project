<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_background"
    tools:context=".ui.catalog.ProductListActivity">

    <ImageButton
        android:id="@+id/btnBack"
        android:layout_width="40dp"
        android:layout_height="56dp"
        android:layout_marginStart="8dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="@android:string/cancel"
        android:src="@drawable/ic_arrow_back"
        app:tint="@color/color_text_primary"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:ellipsize="end"
        android:gravity="center"
        android:maxLines="1"
        android:textColor="@color/color_text_primary"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@id/btnBack"
        app:layout_constraintEnd_toStartOf="@id/btnFilter"
        app:layout_constraintStart_toEndOf="@id/btnBack"
        app:layout_constraintTop_toTopOf="parent"
        tools:text="Tat ca san pham" />

    <ImageButton
        android:id="@+id/btnFilter"
        android:layout_width="40dp"
        android:layout_height="56dp"
        android:layout_marginEnd="8dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="@null"
        android:src="@drawable/ic_filter"
        app:tint="@color/color_text_primary"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <View
        android:id="@+id/dividerHeader"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/color_field_border"
        app:layout_constraintTop_toBottomOf="@id/tvTitle" />

    <HorizontalScrollView
        android:id="@+id/scrollFilterChips"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:scrollbars="none"
        app:layout_constraintTop_toBottomOf="@id/dividerHeader">
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="12dp">
            <TextView
                android:id="@+id/chipKinhMat"
                android:layout_width="wrap_content"
                android:layout_height="30dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_btn_wine_outline"
                android:gravity="center"
                android:paddingHorizontal="14dp"
                android:text="Kính Mát"
                android:textColor="@color/brand_wine"
                android:textSize="12sp" />
            <TextView
                android:id="@+id/chipShape"
                android:layout_width="wrap_content"
                android:layout_height="30dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_btn_wine_outline"
                android:gravity="center"
                android:paddingHorizontal="14dp"
                android:text="Shape Kính ⌄"
                android:textColor="@color/brand_wine"
                android:textSize="12sp" />
            <TextView
                android:id="@+id/chipGong"
                android:layout_width="wrap_content"
                android:layout_height="30dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_btn_wine_outline"
                android:gravity="center"
                android:paddingHorizontal="14dp"
                android:text="Gọng Kính ⌄"
                android:textColor="@color/brand_wine"
                android:textSize="12sp" />
            <TextView
                android:id="@+id/chipPhuKien"
                android:layout_width="wrap_content"
                android:layout_height="30dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_btn_wine_outline"
                android:gravity="center"
                android:paddingHorizontal="14dp"
                android:text="Phụ Kiện ⌄"
                android:textColor="@color/brand_wine"
                android:textSize="12sp" />
            <TextView
                android:id="@+id/chipLuxury"
                android:layout_width="wrap_content"
                android:layout_height="30dp"
                android:background="@drawable/bg_btn_wine_outline"
                android:gravity="center"
                android:paddingHorizontal="14dp"
                android:text="Bộ Sưu Tập ⌄"
                android:textColor="@color/brand_wine"
                android:textSize="12sp" />
        </LinearLayout>
    </HorizontalScrollView>

    <View
        android:id="@+id/dividerChips"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/color_field_border"
        app:layout_constraintTop_toBottomOf="@id/scrollFilterChips" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvProducts"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:paddingHorizontal="11dp"
        android:paddingBottom="16dp"
        app:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
        app:spanCount="2"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/dividerChips"
        tools:listitem="@layout/item_product" />

    <TextView
        android:id="@+id/tvEmpty"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="60dp"
        android:layout_marginHorizontal="24dp"
        android:gravity="center"
        android:text="Danh muc nay chua co san pham, doi ngu dang cap nhat them."
        android:textColor="@color/color_text_secondary"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/dividerChips"
        tools:visibility="visible" />

    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>