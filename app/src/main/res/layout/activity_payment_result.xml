<?xml version="1.0" encoding="utf-8"?>
<!-- LA_Payment — kết quả đặt hàng: ĐANG CHỜ THANH TOÁN (bank) / ĐẶT HÀNG THÀNH CÔNG (COD) -->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_background"
    tools:context=".ui.order.PaymentResultActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="24dp">

        <!-- Khối trạng thái -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/white"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:padding="24dp">

            <ImageView
                android:id="@+id/ivStatus"
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:contentDescription="@null"
                tools:src="@drawable/ic_check_circle" />

            <TextView
                android:id="@+id/tvStatusTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:textColor="@color/color_text_primary"
                android:textSize="18sp"
                android:textStyle="bold"
                tools:text="THANH TOÁN THÀNH CÔNG" />

            <TextView
                android:id="@+id/tvOrderCode"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:textColor="@color/color_price"
                android:textSize="14sp"
                android:textStyle="bold"
                tools:text="Mã đơn: GLS-260702-0421" />

            <TextView
                android:id="@+id/tvStatusDesc"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center"
                android:textColor="@color/color_text_secondary"
                android:textSize="13sp"
                tools:text="Cảm ơn bạn đã đặt hàng!" />

            <!-- Thông tin chuyển khoản — chỉ hiện khi BANK_TRANSFER -->
            <LinearLayout
                android:id="@+id/llBankInfo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_card_vietqr"
                android:orientation="vertical"
                android:padding="16dp"
                android:visibility="gone"
                tools:visibility="visible">

                <!-- Header -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Quét mã để thanh toán"
                    android:textColor="@color/brand_wine"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="Dùng bất kỳ ứng dụng ngân hàng nào để quét"
                    android:textColor="@color/color_text_secondary"
                    android:textSize="12sp" />

                <!-- VietQR image — compact2 template có logo MB + QR + tên TK -->
                <ImageView
                    android:id="@+id/ivVietQR"
                    android:layout_width="220dp"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="14dp"
                    android:adjustViewBounds="true"
                    android:contentDescription="@null" />

                <!-- Trạng thái tự động kiểm tra chuyển khoản -->
                <LinearLayout
                    android:id="@+id/llAutoCheck"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:background="@color/white"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="10dp">

                    <ProgressBar
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:indeterminateTint="@color/brand_wine" />

                    <TextView
                        android:id="@+id/tvAutoCheckStatus"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        android:text="Đang tự động kiểm tra giao dịch..."
                        android:textColor="@color/brand_wine"
                        android:textSize="12sp" />
                </LinearLayout>

                <!-- Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="14dp"
                    android:layout_marginBottom="10dp"
                    android:background="@color/brand_beige" />

                <!-- Row: STK + copy button -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Số tài khoản"
                        android:textColor="@color/color_text_secondary"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/tvBankAccount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0977780173"
                        android:textColor="@color/color_text_primary"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/btnCopyAccount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:background="@drawable/bg_btn_wine_filled"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="4dp"
                        android:text="Copy"
                        android:textColor="@color/white"
                        android:textSize="11sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- Row: Số tiền -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Số tiền"
                        android:textColor="@color/color_text_secondary"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/tvBankAmount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/color_price"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        tools:text="1.290.000đ" />
                </LinearLayout>

                <!-- Row: Nội dung CK + copy button -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Nội dung CK"
                        android:textColor="@color/color_text_secondary"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/tvBankContent"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/color_text_primary"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        tools:text="GLASSITY GLS-260702-0421" />

                    <TextView
                        android:id="@+id/btnCopyContent"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:background="@drawable/bg_btn_wine_filled"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="4dp"
                        android:text="Copy"
                        android:textColor="@color/white"
                        android:textSize="11sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <!-- 2 nút hành động -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btnGoHome"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_marginEnd="6dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_btn_black_filled"
                    android:text="@string/payment_go_home"
                    android:textColor="@color/white"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/btnViewOrder"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_marginStart="6dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_btn_black_filled"
                    android:text="@string/payment_view_order"
                    android:textColor="@color/white"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <!-- Có thể bạn cũng thích — chỉ hiện khi đã thanh toán xong (COD/PAID), ẩn lúc đang chờ CK -->
        <LinearLayout
            android:id="@+id/llSuggest"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="16dp"
                android:text="@string/payment_suggest_title"
                android:textColor="@color/color_text_primary"
                android:textSize="15sp"
                android:textStyle="bold" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvSuggest"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:nestedScrollingEnabled="false"
                android:paddingHorizontal="8dp"
                tools:itemCount="4"
                tools:listitem="@layout/item_product" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
