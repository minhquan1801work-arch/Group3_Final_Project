<?xml version="1.0" encoding="utf-8"?>
<!-- LA_Payment — kết quả đặt hàng: ĐANG CHỜ THANH TOÁN (bank) / ĐẶT HÀNG THÀNH CÔNG (COD) -->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_background"
    tools:context=".ui.order.PaymentResultActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="24dp">

        <!-- Khối trạng thái -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/white"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:padding="24dp">

            <ImageView
                android:id="@+id/ivStatus"
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:contentDescription="@null"
                tools:src="@drawable/ic_check_circle" />

            <TextView
                android:id="@+id/tvStatusTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:textColor="@color/color_text_primary"
                android:textSize="18sp"
                android:textStyle="bold"
                tools:text="THANH TOÁN THÀNH CÔNG" />

            <TextView
                android:id="@+id/tvOrderCode"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:textColor="@color/color_price"
                android:textSize="14sp"
                android:textStyle="bold"
                tools:text="Mã đơn: GLS-260702-0421" />

            <TextView
                android:id="@+id/tvStatusDesc"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center"
                android:textColor="@color/color_text_secondary"
                android:textSize="13sp"
                tools:text="Cảm ơn bạn đã đặt hàng!" />

            <!-- Thông tin chuyển khoản — chỉ hiện khi BANK_TRANSFER -->
            <LinearLayout
                android:id="@+id/llBankInfo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_rounded_card"
                android:orientation="vertical"
                android:padding="12dp"
                android:visibility="gone"
                tools:visibility="visible">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Thông tin chuyển khoản"
                    android:textColor="@color/color_text_primary"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvBankDetail"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:lineSpacingExtra="4dp"
                    android:textColor="@color/color_text_secondary"
                    android:textSize="13sp"
                    tools:text="Ngân hàng: Vietcombank\nSTK: 0123456789" />
            </LinearLayout>

            <!-- 2 nút hành động -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btnGoHome"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_marginEnd="6dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_btn_black_outline"
                    android:text="@string/payment_go_home"
                    android:textColor="@color/color_btn_black"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/btnViewOrder"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_marginStart="6dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_btn_black_filled"
                    android:text="@string/payment_view_order"
                    android:textColor="@color/white"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <!-- Có thể bạn cũng thích (Figma: grid sản phẩm dưới màn kết quả) -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="16dp"
            android:text="@string/payment_suggest_title"
            android:textColor="@color/color_text_primary"
            android:textSize="15sp"
            android:textStyle="bold" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvSuggest"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:nestedScrollingEnabled="false"
            android:paddingHorizontal="8dp"
            tools:itemCount="4"
            tools:listitem="@layout/item_product" />

    </LinearLayout>
</ScrollView>
