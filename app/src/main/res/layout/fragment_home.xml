<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_background"
    android:clipToPadding="false"
    android:paddingBottom="88dp"
    tools:context=".ui.catalog.HomeFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- ══════════════════════════════ HEADER BAR ══════════════════════════════ -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/layoutHeader"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@color/color_background"
            android:elevation="2dp">
            <ImageView
                android:id="@+id/btnMenu"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginStart="12dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@null"
                android:padding="8dp"
                android:src="@drawable/ic_menu"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />
            <TextView
                android:id="@+id/tvLogo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:letterSpacing="0.08"
                android:text="Glassity"
                android:textColor="@color/color_text_primary"
                android:textSize="22sp"
                android:textStyle="bold"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="12dp"
                android:orientation="horizontal"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent">
                <ImageView
                    android:id="@+id/btnSearch"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@null"
                    android:padding="8dp"
                    android:src="@drawable/ic_search" />
                <!-- Giỏ hàng + badge số lượng -->
                <FrameLayout
                    android:layout_width="40dp"
                    android:layout_height="40dp">

                    <ImageView
                        android:id="@+id/btnCart"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:contentDescription="@null"
                        android:padding="8dp"
                        android:src="@drawable/ic_nav_cart"
                        app:tint="@color/color_text_primary" />

                    <TextView
                        android:id="@+id/tvCartBadge"
                        android:layout_width="17dp"
                        android:layout_height="17dp"
                        android:layout_gravity="top|end"
                        android:layout_marginTop="3dp"
                        android:layout_marginEnd="1dp"
                        android:background="@drawable/bg_dot_red"
                        android:gravity="center"
                        android:textColor="@color/white"
                        android:textSize="9sp"
                        android:textStyle="bold"
                        android:visibility="gone" />
                </FrameLayout>
            </LinearLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- ══════════════ HERO CAROUSEL: slide giữa to, 2 bên ló ra (Figma) ══════════════ -->
        <androidx.viewpager2.widget.ViewPager2
            android:id="@+id/vpHero"
            android:layout_width="match_parent"
            android:layout_height="230dp"
            android:clipChildren="false"
            android:clipToPadding="false" />

        <!-- ══════════════════════════════ PROMO BANNER ══════════════════════════════ -->
        <!-- Cao gần vuông để thấy trọn ảnh minh họa (Figma) -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/layoutPromoBanner"
            android:layout_width="match_parent"
            android:layout_height="330dp"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_rounded_card"
            android:backgroundTint="#8EC5C8">
            <ImageView
                android:id="@+id/imgPromo"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:scaleType="centerCrop"
                android:contentDescription="@null"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent" />
            <!-- Text + nút căn giữa, dồn xuống dưới (Figma) -->
            <TextView
                android:id="@+id/tvPromoText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:shadowColor="#40000000"
                android:shadowRadius="4"
                android:text="MUA SẢN PHẨM THỨ HAI\nGIẢM NGAY 20%"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"
                app:layout_constraintBottom_toTopOf="@id/btnPromo"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent" />
            <TextView
                android:id="@+id/btnPromo"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="28dp"
                android:background="@drawable/bg_btn_black_filled"
                android:gravity="center"
                android:paddingHorizontal="24dp"
                android:text="Mua ngay"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent" />
        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- ══════════════════════════════ SẢN PHẨM BÁN CHẠY ══════════════════════════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:orientation="vertical">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:letterSpacing="0.05"
                    android:text="SẢN PHẨM BÁN CHẠY"
                    android:textColor="@color/color_text_primary"
                    android:textSize="13sp"
                    android:textStyle="bold" />
                <ImageView
                    android:id="@+id/btnViewAllFeatured"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_chevron_right" />
            </LinearLayout>
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvFeaturedProducts"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:clipToPadding="false"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                tools:listitem="@layout/item_product_featured" />
        </LinearLayout>

        <!-- ══════════════════════════════ CHỌN KÍNH THEO DÁNG MẶT ══════════════════════════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:orientation="vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:letterSpacing="0.05"
                android:text="CHỌN KÍNH THEO DÁNG MẶT"
                android:textColor="@color/color_text_primary"
                android:textSize="13sp"
                android:textStyle="bold" />
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:gravity="center"
                android:orientation="horizontal">
                <LinearLayout
                    android:id="@+id/faceTron"
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:gravity="center" android:orientation="vertical"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:clickable="true" android:focusable="true">
                    <ImageView android:id="@+id/imgFaceTron"
                        android:layout_width="84dp" android:layout_height="84dp"
                        android:scaleType="centerCrop"
                        android:background="@drawable/bg_face_circle"
                        android:contentDescription="@null" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:layout_marginTop="6dp" android:text="TRÒN"
                        android:letterSpacing="0.06" android:textStyle="bold"
                        android:textColor="#E56B6F" android:textSize="11sp" />
                </LinearLayout>
                <LinearLayout
                    android:id="@+id/faceTraiXoan"
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:gravity="center" android:orientation="vertical"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:clickable="true" android:focusable="true">
                    <ImageView android:id="@+id/imgFaceTraiXoan"
                        android:layout_width="84dp" android:layout_height="84dp"
                        android:scaleType="centerCrop"
                        android:background="@drawable/bg_face_circle"
                        android:contentDescription="@null" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:layout_marginTop="6dp" android:text="TRÁI XOAN"
                        android:letterSpacing="0.06" android:textStyle="bold"
                        android:textColor="#2FA7A0" android:textSize="11sp" />
                </LinearLayout>
                <LinearLayout
                    android:id="@+id/faceTraiTim"
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:gravity="center" android:orientation="vertical"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:clickable="true" android:focusable="true">
                    <ImageView android:id="@+id/imgFaceTraiTim"
                        android:layout_width="84dp" android:layout_height="84dp"
                        android:scaleType="centerCrop"
                        android:background="@drawable/bg_face_circle"
                        android:contentDescription="@null" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:layout_marginTop="6dp" android:text="TRÁI TIM"
                        android:letterSpacing="0.06" android:textStyle="bold"
                        android:textColor="#D4A72C" android:textSize="11sp" />
                </LinearLayout>
            </LinearLayout>
            <!-- Hàng 2: 2 dáng mặt căn giữa (Figma) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:gravity="center"
                android:orientation="horizontal">
                <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="0.5" />
                <LinearLayout
                    android:id="@+id/faceKimCuong"
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:gravity="center" android:orientation="vertical"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:clickable="true" android:focusable="true">
                    <ImageView android:id="@+id/imgFaceKimCuong"
                        android:layout_width="84dp" android:layout_height="84dp"
                        android:scaleType="centerCrop"
                        android:background="@drawable/bg_face_circle"
                        android:contentDescription="@null" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:layout_marginTop="6dp" android:text="KIM CƯƠNG"
                        android:letterSpacing="0.06" android:textStyle="bold"
                        android:textColor="#4A7BD9" android:textSize="11sp" />
                </LinearLayout>
                <LinearLayout
                    android:id="@+id/faceVuong"
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:gravity="center" android:orientation="vertical"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:clickable="true" android:focusable="true">
                    <ImageView android:id="@+id/imgFaceVuong"
                        android:layout_width="84dp" android:layout_height="84dp"
                        android:scaleType="centerCrop"
                        android:background="@drawable/bg_face_circle"
                        android:contentDescription="@null" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:layout_marginTop="6dp" android:text="VUÔNG"
                        android:letterSpacing="0.06" android:textStyle="bold"
                        android:textColor="#E8963A" android:textSize="11sp" />
                </LinearLayout>
                <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="0.5" />
            </LinearLayout>
        </LinearLayout>

        <!-- ══════════════════════════════ BỘ SƯU TẬP ══════════════════════════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:letterSpacing="0.05"
                    android:text="BỘ SƯU TẬP"
                    android:textColor="@color/color_text_primary"
                    android:textSize="13sp"
                    android:textStyle="bold" />
                <ImageView
                    android:id="@+id/btnViewAllCollections"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_chevron_right" />
            </LinearLayout>

            <!-- Carousel lướt ngang: mỗi card = ảnh dọc + tên BST bên dưới (Figma) -->
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:scrollbars="none">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingHorizontal="16dp">

                    <LinearLayout
                        android:id="@+id/tileMonochrome"
                        android:layout_width="200dp"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="14dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground"
                        android:orientation="vertical">
                        <ImageView
                            android:id="@+id/imgMonochrome"
                            android:layout_width="match_parent"
                            android:layout_height="265dp"
                            android:scaleType="centerCrop"
                            android:src="@color/brand_dark"
                            android:contentDescription="@null" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:letterSpacing="0.12"
                            android:text="MONOCHROME COLLECTION"
                            android:textColor="@color/color_text_primary"
                            android:textSize="11sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/tileEssential"
                        android:layout_width="200dp"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="14dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground"
                        android:orientation="vertical">
                        <ImageView
                            android:id="@+id/imgEssential"
                            android:layout_width="match_parent"
                            android:layout_height="265dp"
                            android:scaleType="centerCrop"
                            android:src="@color/brand_taupe"
                            android:contentDescription="@null" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:letterSpacing="0.12"
                            android:text="ESSENTIAL ACETATE"
                            android:textColor="@color/color_text_primary"
                            android:textSize="11sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/tileSunlight"
                        android:layout_width="200dp"
                        android:layout_height="wrap_content"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground"
                        android:orientation="vertical">
                        <ImageView
                            android:id="@+id/imgSunlight"
                            android:layout_width="match_parent"
                            android:layout_height="265dp"
                            android:scaleType="centerCrop"
                            android:src="@color/color_field_border"
                            android:contentDescription="@null" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:letterSpacing="0.12"
                            android:text="SUNLIGHT STUDIO"
                            android:textColor="@color/color_text_primary"
                            android:textSize="11sp" />
                    </LinearLayout>
                </LinearLayout>
            </HorizontalScrollView>

        </LinearLayout>

        <!-- ══════════════════════════════ BLOG ══════════════════════════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:letterSpacing="0.05"
                    android:text="BLOG"
                    android:textColor="@color/color_text_primary"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:clipToPadding="false"
                android:paddingHorizontal="16dp"
                android:scrollbars="none">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <!-- Blog card 1 -->
                    <LinearLayout
                        android:id="@+id/blogCard1"
                        android:layout_width="220dp"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="12dp"
                        android:background="@drawable/bg_rounded_card"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground"
                        android:orientation="vertical">
                        <ImageView
                            android:id="@+id/imgBlog1"
                            android:layout_width="match_parent"
                            android:layout_height="120dp"
                            android:scaleType="centerCrop"
                            android:background="@color/color_field_border"
                            android:contentDescription="@null" />
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="12dp">
                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Cách chọn kính phù hợp dáng khuôn mặt"
                                android:textColor="@color/color_text_primary"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                android:maxLines="2"
                                android:ellipsize="end" />
                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="Glassity Guide"
                                android:textColor="@color/color_hint"
                                android:textSize="11sp" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Blog card 2 -->
                    <LinearLayout
                        android:id="@+id/blogCard2"
                        android:layout_width="220dp"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="12dp"
                        android:background="@drawable/bg_rounded_card"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground"
                        android:orientation="vertical">
                        <ImageView
                            android:id="@+id/imgBlog2"
                            android:layout_width="match_parent"
                            android:layout_height="120dp"
                            android:scaleType="centerCrop"
                            android:background="@color/color_field_border"
                            android:contentDescription="@null" />
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="12dp">
                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Xu hướng kính mắt 2025 – Những frame đang hot"
                                android:textColor="@color/color_text_primary"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                android:maxLines="2"
                                android:ellipsize="end" />
                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="Glassity Guide"
                                android:textColor="@color/color_hint"
                                android:textSize="11sp" />
                        </LinearLayout>
                    </LinearLayout>

                </LinearLayout>
            </HorizontalScrollView>
        </LinearLayout>

        <!-- ══════════════ LỢI ÍCH: 6 tile 2 cột (Figma) ══════════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:layout_marginHorizontal="16dp"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <LinearLayout style="@style/BenefitTile"
                    android:layout_marginEnd="8dp">
                    <TextView style="@style/BenefitIcon" android:text="&#x1F69A;" />
                    <TextView style="@style/BenefitText" android:text="Miễn phí\nvận chuyển từ 399K" />
                </LinearLayout>
                <LinearLayout style="@style/BenefitTile">
                    <TextView style="@style/BenefitIcon" android:text="&#x1F453;" />
                    <TextView style="@style/BenefitText" android:text="Đo mắt miễn phí\ntại cửa hàng" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal">
                <LinearLayout style="@style/BenefitTile"
                    android:layout_marginEnd="8dp">
                    <TextView style="@style/BenefitIcon" android:text="&#x1F4E6;" />
                    <TextView style="@style/BenefitText" android:text="Đổi trả\ntrong 30 ngày" />
                </LinearLayout>
                <LinearLayout style="@style/BenefitTile">
                    <TextView style="@style/BenefitIcon" android:text="&#x1F9D1;&#x200D;&#x1F4BC;" />
                    <TextView style="@style/BenefitText" android:text="Nhân viên hỗ trợ\n24/7" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal">
                <LinearLayout style="@style/BenefitTile"
                    android:layout_marginEnd="8dp">
                    <TextView style="@style/BenefitIcon" android:text="&#x1F3C5;" />
                    <TextView style="@style/BenefitText" android:text="Cam kết\nchính hãng 100%" />
                </LinearLayout>
                <LinearLayout style="@style/BenefitTile">
                    <TextView style="@style/BenefitIcon" android:text="&#x1F6E1;&#xFE0F;" />
                    <TextView style="@style/BenefitText" android:text="Thanh toán\nnhanh, an toàn" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- ══════════════ KHÁM PHÁ GLASSITY: ảnh + chữ dọc (Figma) ══════════════ -->
        <LinearLayout
            android:id="@+id/bannerKhamPha"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:background="@color/white"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            android:orientation="vertical"
            android:paddingVertical="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="420dp"
                android:clipChildren="false"
                android:orientation="horizontal"
                android:paddingStart="24dp"
                android:paddingEnd="8dp">

                <ImageView
                    android:id="@+id/imgKhamPha"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:scaleType="centerCrop"
                    android:src="@color/color_field_border"
                    android:contentDescription="@null" />

                <!-- Cột chữ dọc bên phải -->
                <FrameLayout
                    android:layout_width="88dp"
                    android:layout_height="match_parent"
                    android:clipChildren="false">
                    <TextView
                        android:layout_width="400dp"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:fontFamily="serif"
                        android:gravity="center"
                        android:letterSpacing="0.15"
                        android:rotation="90"
                        android:text="GLASSITY"
                        android:textColor="@color/color_text_primary"
                        android:textSize="34sp"
                        android:translationX="-14dp" />
                    <TextView
                        android:layout_width="400dp"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:gravity="center"
                        android:letterSpacing="0.2"
                        android:rotation="90"
                        android:text="ĐỊNH NGHĨA PHONG CÁCH QUA TỪNG ÁNH NHÌN"
                        android:textColor="@color/color_text_secondary"
                        android:textSize="9sp"
                        android:translationX="22dp" />
                </FrameLayout>
            </LinearLayout>

            <TextView
                android:id="@+id/tvKhamPhaLink"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="20dp"
                android:letterSpacing="0.12"
                android:text="KHÁM PHÁ GLASSITY"
                android:textColor="@color/color_text_primary"
                android:textSize="13sp" />
        </LinearLayout>

        <!-- ══════════════ FOOTER: nền sáng, căn giữa (Figma) ══════════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:background="#F7F5F2"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingVertical="28dp">

            <!-- Social icons -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="horizontal">
                <ImageView
                    android:id="@+id/footerTw"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@null"
                    android:padding="8dp"
                    android:src="@drawable/ic_social_x" />
                <ImageView
                    android:id="@+id/footerIg"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_marginHorizontal="20dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@null"
                    android:padding="8dp"
                    android:src="@drawable/ic_social_ig" />
                <ImageView
                    android:id="@+id/footerYt"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@null"
                    android:padding="8dp"
                    android:src="@drawable/ic_social_yt" />
            </LinearLayout>

            <!-- Ornament ─◇─ -->
            <LinearLayout
                android:layout_width="220dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">
                <View android:layout_width="0dp" android:layout_height="0.7dp"
                    android:layout_weight="1" android:background="#C9C3BB" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_marginHorizontal="8dp" android:text="&#x25C7;"
                    android:textColor="#C9C3BB" android:textSize="10sp" />
                <View android:layout_width="0dp" android:layout_height="0.7dp"
                    android:layout_weight="1" android:background="#C9C3BB" />
            </LinearLayout>

            <!-- Contact info -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:fontFamily="serif"
                android:text="support@glassity.com"
                android:textColor="@color/color_text_primary"
                android:textSize="13sp" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:fontFamily="serif"
                android:text="+8386 123 789"
                android:textColor="@color/color_text_primary"
                android:textSize="13sp" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:fontFamily="serif"
                android:text="08:00 - 22:00 - Mỗi ngày"
                android:textColor="@color/color_text_primary"
                android:textSize="13sp" />

            <!-- Ornament ─◇─ -->
            <LinearLayout
                android:layout_width="220dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">
                <View android:layout_width="0dp" android:layout_height="0.7dp"
                    android:layout_weight="1" android:background="#C9C3BB" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_marginHorizontal="8dp" android:text="&#x25C7;"
                    android:textColor="#C9C3BB" android:textSize="10sp" />
                <View android:layout_width="0dp" android:layout_height="0.7dp"
                    android:layout_weight="1" android:background="#C9C3BB" />
            </LinearLayout>

            <!-- Links: About / Contact / Policy — trang đích bổ sung sau -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:orientation="horizontal">
                <TextView
                    android:id="@+id/footerAbout"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:fontFamily="serif"
                    android:padding="6dp"
                    android:text="About"
                    android:textColor="@color/color_text_primary"
                    android:textSize="14sp" />
                <TextView
                    android:id="@+id/footerContact"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="28dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:fontFamily="serif"
                    android:padding="6dp"
                    android:text="Contact"
                    android:textColor="@color/color_text_primary"
                    android:textSize="14sp" />
                <TextView
                    android:id="@+id/footerPolicy"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:fontFamily="serif"
                    android:padding="6dp"
                    android:text="Policy"
                    android:textColor="@color/color_text_primary"
                    android:textSize="14sp" />
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:background="#EDEAE5"
                android:gravity="center"
                android:paddingVertical="10dp"
                android:text="Glassity© Bản quyền được bảo hộ."
                android:textColor="@color/color_text_secondary"
                android:textSize="11sp" />
        </LinearLayout>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
