<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_background"
    android:clipToPadding="false"
    android:paddingBottom="88dp"
    tools:context=".ui.catalog.HomeFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- ══════════════════════════════ HEADER BAR ══════════════════════════════ -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/layoutHeader"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@color/color_background"
            android:elevation="2dp">
            <ImageView
                android:id="@+id/btnMenu"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginStart="12dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@null"
                android:padding="8dp"
                android:src="@drawable/ic_menu"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />
            <TextView
                android:id="@+id/tvLogo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:letterSpacing="0.08"
                android:text="Glassity"
                android:textColor="@color/color_text_primary"
                android:textSize="22sp"
                android:textStyle="bold"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="12dp"
                android:orientation="horizontal"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent">
                <ImageView
                    android:id="@+id/btnSearch"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@null"
                    android:padding="8dp"
                    android:src="@drawable/ic_search" />
                <ImageView
                    android:id="@+id/btnCart"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@null"
                    android:padding="8dp"
                    android:src="@drawable/ic_nav_cart"
                    app:tint="@color/color_text_primary" />
            </LinearLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- ══════════════════════════════ HERO CAROUSEL ══════════════════════════════ -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="220dp">

            <androidx.viewpager2.widget.ViewPager2
                android:id="@+id/vpHero"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />

            <!-- Dot indicators -->
            <LinearLayout
                android:id="@+id/llHeroDots"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom|center_horizontal"
                android:layout_marginBottom="12dp"
                android:orientation="horizontal" />
        </FrameLayout>

        <!-- ══════════════════════════════ PROMO BANNER ══════════════════════════════ -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/layoutPromoBanner"
            android:layout_width="match_parent"
            android:layout_height="140dp"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_rounded_card"
            android:backgroundTint="#8EC5C8">
            <ImageView
                android:id="@+id/imgPromo"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:scaleType="centerCrop"
                android:contentDescription="@null"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent" />
            <TextView
                android:id="@+id/tvPromoText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginTop="20dp"
                android:layout_marginEnd="100dp"
                android:text="Mua sản phẩm thứ hai\ngiảm ngay 20%"
                android:textColor="#FFFFFF"
                android:textSize="17sp"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />
            <TextView
                android:id="@+id/btnPromo"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:layout_marginStart="20dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_btn_wine_filled"
                android:gravity="center"
                android:paddingHorizontal="16dp"
                android:text="Mua ngay"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tvPromoText" />
        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- ══════════════════════════════ SẢN PHẨM BÁN CHẠY ══════════════════════════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:orientation="vertical">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:letterSpacing="0.05"
                    android:text="SẢN PHẨM BÁN CHẠY"
                    android:textColor="@color/color_text_primary"
                    android:textSize="13sp"
                    android:textStyle="bold" />
                <ImageView
                    android:id="@+id/btnViewAllFeatured"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_chevron_right" />
            </LinearLayout>
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvFeaturedProducts"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:clipToPadding="false"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                tools:listitem="@layout/item_product_featured" />
        </LinearLayout>

        <!-- ══════════════════════════════ CHỌN KÍNH THEO DÁNG MẶT ══════════════════════════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:orientation="vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:letterSpacing="0.05"
                android:text="CHỌN KÍNH THEO DÁNG MẶT"
                android:textColor="@color/color_text_primary"
                android:textSize="13sp"
                android:textStyle="bold" />
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:gravity="center"
                android:orientation="horizontal">
                <LinearLayout
                    android:id="@+id/faceTron"
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:gravity="center" android:orientation="vertical"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:clickable="true" android:focusable="true">
                    <ImageView android:id="@+id/imgFaceTron"
                        android:layout_width="64dp" android:layout_height="64dp"
                        android:scaleType="centerCrop"
                        android:background="@drawable/bg_face_circle"
                        android:contentDescription="@null" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:layout_marginTop="4dp" android:text="TRÒN"
                        android:textColor="@color/color_text_primary" android:textSize="10sp" />
                </LinearLayout>
                <LinearLayout
                    android:id="@+id/faceTraiXoan"
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:gravity="center" android:orientation="vertical"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:clickable="true" android:focusable="true">
                    <ImageView android:id="@+id/imgFaceTraiXoan"
                        android:layout_width="64dp" android:layout_height="64dp"
                        android:scaleType="centerCrop"
                        android:background="@drawable/bg_face_circle"
                        android:contentDescription="@null" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:layout_marginTop="4dp" android:text="TRÁI XOAN"
                        android:textColor="@color/color_text_primary" android:textSize="10sp" />
                </LinearLayout>
                <LinearLayout
                    android:id="@+id/faceTraiTim"
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:gravity="center" android:orientation="vertical"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:clickable="true" android:focusable="true">
                    <ImageView android:id="@+id/imgFaceTraiTim"
                        android:layout_width="64dp" android:layout_height="64dp"
                        android:scaleType="centerCrop"
                        android:background="@drawable/bg_face_circle"
                        android:contentDescription="@null" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:layout_marginTop="4dp" android:text="TRÁI TIM"
                        android:textColor="@color/color_text_primary" android:textSize="10sp" />
                </LinearLayout>
            </LinearLayout>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:gravity="center"
                android:orientation="horizontal">
                <LinearLayout
                    android:id="@+id/faceKimCuong"
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:gravity="center" android:orientation="vertical"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:clickable="true" android:focusable="true">
                    <ImageView android:id="@+id/imgFaceKimCuong"
                        android:layout_width="64dp" android:layout_height="64dp"
                        android:scaleType="centerCrop"
                        android:background="@drawable/bg_face_circle"
                        android:contentDescription="@null" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:layout_marginTop="4dp" android:text="KIM CƯƠNG"
                        android:textColor="@color/color_text_primary" android:textSize="10sp" />
                </LinearLayout>
                <LinearLayout
                    android:id="@+id/faceVuong"
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:gravity="center" android:orientation="vertical"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:clickable="true" android:focusable="true">
                    <ImageView android:id="@+id/imgFaceVuong"
                        android:layout_width="64dp" android:layout_height="64dp"
                        android:scaleType="centerCrop"
                        android:background="@drawable/bg_face_circle"
                        android:contentDescription="@null" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:layout_marginTop="4dp" android:text="VUÔNG"
                        android:textColor="@color/color_text_primary" android:textSize="10sp" />
                </LinearLayout>
                <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1" />
            </LinearLayout>
        </LinearLayout>

        <!-- ══════════════════════════════ BỘ SƯU TẬP ══════════════════════════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:letterSpacing="0.05"
                    android:text="BỘ SƯU TẬP"
                    android:textColor="@color/color_text_primary"
                    android:textSize="13sp"
                    android:textStyle="bold" />
                <ImageView
                    android:id="@+id/btnViewAllCollections"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_chevron_right" />
            </LinearLayout>

            <!-- Carousel lướt ngang: mỗi card = ảnh dọc + tên BST bên dưới (Figma) -->
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:scrollbars="none">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingHorizontal="16dp">

                    <LinearLayout
                        android:id="@+id/tileMonochrome"
                        android:layout_width="200dp"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="14dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground"
                        android:orientation="vertical">
                        <ImageView
                            android:id="@+id/imgMonochrome"
                            android:layout_width="match_parent"
                            android:layout_height="265dp"
                            android:scaleType="centerCrop"
                            android:src="@color/brand_dark"
                            android:contentDescription="@null" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:letterSpacing="0.12"
                            android:text="MONOCHROME COLLECTION"
                            android:textColor="@color/color_text_primary"
                            android:textSize="11sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/tileEssential"
                        android:layout_width="200dp"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="14dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground"
                        android:orientation="vertical">
                        <ImageView
                            android:id="@+id/imgEssential"
                            android:layout_width="match_parent"
                            android:layout_height="265dp"
                            android:scaleType="centerCrop"
                            android:src="@color/brand_taupe"
                            android:contentDescription="@null" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:letterSpacing="0.12"
                            android:text="ESSENTIAL ACETATE"
                            android:textColor="@color/color_text_primary"
                            android:textSize="11sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/tileSunlight"
                        android:layout_width="200dp"
                        android:layout_height="wrap_content"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground"
                        android:orientation="vertical">
                        <ImageView
                            android:id="@+id/imgSunlight"
                            android:layout_width="match_parent"
                            android:layout_height="265dp"
                            android:scaleType="centerCrop"
                            android:src="@color/color_field_border"
                            android:contentDescription="@null" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:letterSpacing="0.12"
                            android:text="SUNLIGHT STUDIO"
                            android:textColor="@color/color_text_primary"
                            android:textSize="11sp" />
                    </LinearLayout>
                </LinearLayout>
            </HorizontalScrollView>

        </LinearLayout>

        <!-- ══════════════════════════════ LỢI ÍCH ══════════════════════════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:layout_marginHorizontal="16dp"
            android:background="@color/white"
            android:padding="12dp"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:layout_marginEnd="8dp"
                    android:gravity="center_vertical" android:orientation="horizontal">
                    <TextView android:layout_width="28dp" android:layout_height="28dp"
                        android:gravity="center" android:text="&#x1F69A;" android:textSize="16sp" />
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:layout_marginStart="6dp"
                        android:text="Miễn phí vận chuyển từ 399K"
                        android:textColor="@color/color_text_primary" android:textSize="10sp" />
                </LinearLayout>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:gravity="center_vertical" android:orientation="horizontal">
                    <TextView android:layout_width="28dp" android:layout_height="28dp"
                        android:gravity="center" android:text="&#x1F504;" android:textSize="16sp" />
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:layout_marginStart="6dp"
                        android:text="Đổi trả trong 30 ngày"
                        android:textColor="@color/color_text_primary" android:textSize="10sp" />
                </LinearLayout>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:layout_marginVertical="10dp" android:background="@color/color_field_border" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:layout_marginEnd="8dp"
                    android:gravity="center_vertical" android:orientation="horizontal">
                    <TextView android:layout_width="28dp" android:layout_height="28dp"
                        android:gravity="center" android:text="&#x1F4AC;" android:textSize="16sp" />
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:layout_marginStart="6dp"
                        android:text="Nhân viên hỗ trợ 24/7"
                        android:textColor="@color/color_text_primary" android:textSize="10sp" />
                </LinearLayout>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:gravity="center_vertical" android:orientation="horizontal">
                    <TextView android:layout_width="28dp" android:layout_height="28dp"
                        android:gravity="center" android:text="&#x2705;" android:textSize="16sp" />
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:layout_marginStart="6dp"
                        android:text="Cam kết chính hãng 100%"
                        android:textColor="@color/color_text_primary" android:textSize="10sp" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- ══════════════════════════════ SẢN PHẨM NỔI BẬT ══════════════════════════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:orientation="vertical">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:letterSpacing="0.05"
                    android:text="SẢN PHẨM NỔI BẬT"
                    android:textColor="@color/color_text_primary"
                    android:textSize="13sp"
                    android:textStyle="bold" />
                <ImageView
                    android:id="@+id/btnViewAllProducts"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_chevron_right" />
            </LinearLayout>
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvProducts"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_marginHorizontal="11dp"
                android:nestedScrollingEnabled="false"
                app:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
                app:spanCount="2"
                tools:listitem="@layout/item_product" />
            <TextView
                android:id="@+id/tvEmptyProducts"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:gravity="center"
                android:text="Chưa có sản phẩm nào, đội ngũ đang cập nhật."
                android:textColor="@color/color_text_secondary"
                android:visibility="gone"
                tools:visibility="visible" />
        </LinearLayout>

        <!-- ══════════════════════════════ BLOG ══════════════════════════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:letterSpacing="0.05"
                    android:text="BLOG"
                    android:textColor="@color/color_text_primary"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:clipToPadding="false"
                android:paddingHorizontal="16dp"
                android:scrollbars="none">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <!-- Blog card 1 -->
                    <LinearLayout
                        android:id="@+id/blogCard1"
                        android:layout_width="220dp"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="12dp"
                        android:background="@drawable/bg_rounded_card"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground"
                        android:orientation="vertical">
                        <ImageView
                            android:id="@+id/imgBlog1"
                            android:layout_width="match_parent"
                            android:layout_height="120dp"
                            android:scaleType="centerCrop"
                            android:background="@color/color_field_border"
                            android:contentDescription="@null" />
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="12dp">
                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Cách chọn kính phù hợp dáng khuôn mặt"
                                android:textColor="@color/color_text_primary"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                android:maxLines="2"
                                android:ellipsize="end" />
                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="Glassity Guide"
                                android:textColor="@color/color_hint"
                                android:textSize="11sp" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Blog card 2 -->
                    <LinearLayout
                        android:id="@+id/blogCard2"
                        android:layout_width="220dp"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="12dp"
                        android:background="@drawable/bg_rounded_card"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground"
                        android:orientation="vertical">
                        <ImageView
                            android:id="@+id/imgBlog2"
                            android:layout_width="match_parent"
                            android:layout_height="120dp"
                            android:scaleType="centerCrop"
                            android:background="@color/color_field_border"
                            android:contentDescription="@null" />
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="12dp">
                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Xu hướng kính mắt 2025 – Những frame đang hot"
                                android:textColor="@color/color_text_primary"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                android:maxLines="2"
                                android:ellipsize="end" />
                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="Glassity Guide"
                                android:textColor="@color/color_hint"
                                android:textSize="11sp" />
                        </LinearLayout>
                    </LinearLayout>

                </LinearLayout>
            </HorizontalScrollView>
        </LinearLayout>

        <!-- ══════════════════════════════ KHÁM PHÁ GLASSITY banner ══════════════════════════════ -->
        <FrameLayout
            android:id="@+id/bannerKhamPha"
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:layout_marginTop="28dp"
            android:layout_marginHorizontal="16dp"
            android:background="@drawable/bg_rounded_card"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground">

            <ImageView
                android:id="@+id/imgKhamPha"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@color/brand_dark"
                android:contentDescription="@null" />

            <!-- Gradient overlay -->
            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:alpha="0.4"
                android:background="@color/brand_dark" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:gravity="center"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:letterSpacing="0.12"
                    android:text="KHÁM PHÁ"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:letterSpacing="0.08"
                    android:text="Glassity"
                    android:textColor="#FFFFFF"
                    android:textSize="30sp"
                    android:textStyle="bold" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_btn_wine_filled"
                    android:gravity="center"
                    android:paddingHorizontal="20dp"
                    android:paddingVertical="6dp"
                    android:text="Xem thêm"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp" />
            </LinearLayout>
        </FrameLayout>

        <!-- ══════════════════════════════ FOOTER ══════════════════════════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:background="@color/brand_dark"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:letterSpacing="0.08"
                android:text="Glassity"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Kính mắt thời trang – Phong cách của bạn"
                android:textColor="#AAAAAA"
                android:textSize="12sp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="0.5dp"
                android:layout_marginVertical="16dp"
                android:background="#444444" />

            <!-- Links -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:id="@+id/footerAbout"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingVertical="4dp"
                        android:text="Về Glassity"
                        android:textColor="#CCCCCC"
                        android:textSize="12sp" />
                    <TextView
                        android:id="@+id/footerContact"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingVertical="4dp"
                        android:text="Liên hệ"
                        android:textColor="#CCCCCC"
                        android:textSize="12sp" />
                    <TextView
                        android:id="@+id/footerPolicy"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingVertical="4dp"
                        android:text="Chính sách bảo mật"
                        android:textColor="#CCCCCC"
                        android:textSize="12sp" />
                </LinearLayout>
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingVertical="4dp"
                        android:text="Theo dõi chúng tôi"
                        android:textColor="#CCCCCC"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:orientation="horizontal">
                        <TextView
                            android:id="@+id/footerFb"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:gravity="center"
                            android:text="f"
                            android:textColor="#FFFFFF"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                        <TextView
                            android:id="@+id/footerIg"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:layout_marginStart="4dp"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:gravity="center"
                            android:text="ig"
                            android:textColor="#FFFFFF"
                            android:textSize="12sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="0.5dp"
                android:layout_marginVertical="16dp"
                android:background="#444444" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="© 2025 Glassity. All rights reserved."
                android:textColor="#666666"
                android:textSize="11sp" />
        </LinearLayout>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
