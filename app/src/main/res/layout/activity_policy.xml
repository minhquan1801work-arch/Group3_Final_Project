<?xml version="1.0" encoding="utf-8"?>
<!-- DL_FAQ / DL_Warranty / DL_Policy (Figma) — trang nội dung chính sách dùng chung -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:orientation="vertical">

    <!-- Header: < Quay lại -->
    <LinearLayout
        android:id="@+id/btnBack"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="?attr/selectableItemBackground"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="12dp">

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:contentDescription="@null"
            android:src="@drawable/ic_chevron_right"
            android:rotation="180"
            app:tint="@color/color_text_primary" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:text="Quay lại"
            android:textColor="@color/color_text_primary"
            android:textSize="14sp" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/color_divider" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingTop="24dp"
            android:paddingBottom="24dp">

            <TextView
                android:id="@+id/tvPolicyTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="serif"
                android:gravity="center"
                android:letterSpacing="0.12"
                android:textColor="@color/color_text_primary"
                android:textSize="18sp"
                tools:text="CÂU HỎI THƯỜNG GẶP" />

            <!-- Ornament ─◇─ (đồng bộ style About/Footer) -->
            <LinearLayout
                android:layout_width="140dp"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="10dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">
                <View android:layout_width="0dp" android:layout_height="0.7dp"
                    android:layout_weight="1" android:background="@color/color_divider" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_marginHorizontal="8dp" android:text="&#x25C7;"
                    android:textColor="@color/color_hint" android:textSize="10sp" />
                <View android:layout_width="0dp" android:layout_height="0.7dp"
                    android:layout_weight="1" android:background="@color/color_divider" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvPolicyContent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:lineSpacingExtra="4dp"
                android:textColor="@color/color_text_body"
                android:textSize="13sp"
                tools:text="Nội dung chính sách..." />
        </LinearLayout>
    </ScrollView>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/color_divider" />

    <!-- Footer bản quyền (Figma) -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fontFamily="serif"
        android:gravity="center"
        android:paddingVertical="12dp"
        android:text="Glassity© Bản quyền được bảo hộ."
        android:textColor="@color/color_hint"
        android:textSize="11sp" />

</LinearLayout>
