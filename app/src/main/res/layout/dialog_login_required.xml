<?xml version="1.0" encoding="utf-8"?>
<!-- Dialog yêu cầu đăng nhập — hiện thay Toast thuần ở mọi chỗ cần tài khoản -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_dialog_card"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:paddingHorizontal="24dp"
    android:paddingTop="32dp"
    android:paddingBottom="24dp">

    <!-- Logo Glassity trong vòng tròn cream -->
    <FrameLayout
        android:layout_width="72dp"
        android:layout_height="72dp"
        android:background="@drawable/bg_face_circle">

        <ImageView
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_gravity="center"
            android:contentDescription="@null"
            android:src="@drawable/ic_logo_glassity" />
    </FrameLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="@string/login_required_title"
        android:textColor="@color/color_text_primary"
        android:textSize="17sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvDialogMessage"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center"
        android:lineSpacingExtra="2dp"
        android:text="@string/login_required_default_msg"
        android:textColor="@color/color_text_secondary"
        android:textSize="13sp" />

    <!-- Nút Đăng nhập -->
    <TextView
        android:id="@+id/btnDialogLogin"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="24dp"
        android:background="@drawable/bg_btn_wine_filled"
        android:gravity="center"
        android:text="@string/login_required_btn_login"
        android:textColor="@color/white"
        android:textSize="14sp"
        android:textStyle="bold" />

    <!-- Nút Để sau -->
    <TextView
        android:id="@+id/btnDialogDismiss"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:layout_marginTop="4dp"
        android:gravity="center"
        android:text="@string/login_required_btn_later"
        android:textColor="@color/color_text_secondary"
        android:textSize="14sp" />

</LinearLayout>
