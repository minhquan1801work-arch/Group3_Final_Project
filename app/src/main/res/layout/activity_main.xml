<?xml version="1.0" encoding="utf-8"?>
<!--
  Màn hình chính: 4 tab dùng CHUNG 1 footer (component duy nhất).

  Footer kiểu FLOATING PILL tối màu (theo design):
  - MaterialCardView bo tròn 32dp, nền tối, nổi cách mép màn hình
  - BottomNavigationView bên trong: chỉ icon (không label),
    tab đang chọn = icon trắng, còn lại xám nhạt
  - Badge đỏ số lượng giỏ hàng gắn trên icon Cart (MainActivity)
  - HideBottomViewOnScrollBehavior: cuộn xuống ẩn, kéo ngược nhẹ hiện lại
-->
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_background">

    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/navHostFragment"
        android:name="androidx.navigation.fragment.NavHostFragment"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:defaultNavHost="true"
        app:navGraph="@navigation/main_nav_graph" />

    <include layout="@layout/layout_bottom_nav" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
