<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_background"
    android:fillViewport="true"
    tools:context=".ui.account.ForgotPasswordActivity">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="28dp"
        android:paddingBottom="24dp">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginTop="16dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@android:string/cancel"
            android:src="@drawable/ic_arrow_back"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="@color/color_text_primary" />

        <!-- ═══ Bước 1: Chọn phương thức + nhập email / SĐT ═══ -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/groupMethodSelect"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toBottomOf="@id/btnBack">

            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:gravity="center"
                android:text="@string/forgot_title"
                android:textColor="@color/color_text_primary"
                android:textSize="24sp"
                android:textStyle="bold"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/tvDesc"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:gravity="center"
                android:text="@string/forgot_desc"
                android:textColor="@color/color_text_secondary"
                android:textSize="14sp"
                app:layout_constraintTop_toBottomOf="@id/tvTitle" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilInput"
                style="@style/Widget.Glassity.TextInputLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:hint="@string/login_email_hint"
                app:layout_constraintTop_toBottomOf="@id/tvDesc">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textEmailAddress" />
            </com.google.android.material.textfield.TextInputLayout>

            <TextView
                android:id="@+id/tvBackToLogin"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:padding="4dp"
                android:text="@string/forgot_back_to_login"
                android:textColor="@color/brand_wine"
                android:textSize="13sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tilInput" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnContinue"
                style="@style/Widget.Glassity.Button.Primary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="@string/forgot_btn_continue"
                app:layout_constraintTop_toBottomOf="@id/tvBackToLogin" />

            <ProgressBar
                android:id="@+id/progressBar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:visibility="gone"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/btnContinue" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- ═══ Bước 2: Email đã gửi (confirmation) ═══ -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/groupEmailSent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/btnBack"
            tools:visibility="gone">

            <ImageView
                android:id="@+id/ivEmailSent"
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:layout_marginTop="28dp"
                android:contentDescription="@null"
                android:src="@drawable/ic_check_circle"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/tvEmailSentTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:gravity="center"
                android:text="@string/forgot_sent_title"
                android:textColor="@color/color_text_primary"
                android:textSize="22sp"
                android:textStyle="bold"
                app:layout_constraintTop_toBottomOf="@id/ivEmailSent" />

            <TextView
                android:id="@+id/tvEmailSentDesc"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:gravity="center"
                android:lineSpacingExtra="3dp"
                android:text="@string/forgot_sent_desc"
                android:textColor="@color/color_text_secondary"
                android:textSize="14sp"
                app:layout_constraintTop_toBottomOf="@id/tvEmailSentTitle"
                tools:text="Glassity đã gửi hướng dẫn đặt lại mật khẩu đến qu***01@gmail.com. Vui lòng kiểm tra hộp thư đến (và mục Spam nếu chưa thấy) rồi làm theo hướng dẫn trong email." />

            <TextView
                android:id="@+id/tvEmailSentHint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:gravity="center"
                android:text="@string/forgot_sent_not_received"
                android:textColor="@color/color_text_secondary"
                android:textSize="13sp"
                app:layout_constraintTop_toBottomOf="@id/tvEmailSentDesc" />

            <TextView
                android:id="@+id/tvResendEmail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:gravity="center"
                android:padding="4dp"
                android:text="@string/forgot_resend"
                android:textColor="@color/brand_wine"
                android:textSize="14sp"
                android:textStyle="bold"
                app:layout_constraintTop_toBottomOf="@id/tvEmailSentHint" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnBackToLoginFinal"
                style="@style/Widget.Glassity.Button.Primary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="@string/forgot_btn_back_login"
                app:layout_constraintTop_toBottomOf="@id/tvResendEmail" />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>
