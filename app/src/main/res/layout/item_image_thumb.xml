<?xml version="1.0" encoding="utf-8"?>
<!-- Thumbnail nhỏ dưới ảnh chính (Figma: hàng 4 thumbnail, cái đang chọn viền cam) -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/frameThumb"
    android:layout_width="64dp"
    android:layout_height="64dp"
    android:layout_marginEnd="8dp"
    android:foreground="?attr/selectableItemBackground">

    <ImageView
        android:id="@+id/ivThumb"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_product_placeholder"
        android:contentDescription="@null"
        android:scaleType="centerCrop" />

    <!-- Viền cam khi được chọn -->
    <View
        android:id="@+id/viewSelected"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_thumb_selected"
        android:visibility="gone" />
</FrameLayout>
