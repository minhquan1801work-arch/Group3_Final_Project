<?xml version="1.0" encoding="utf-8"?>
<!-- LA.Profile — THÀNH VIÊN: thẻ barcode + điểm, grid tiện ích, list chính sách -->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="90dp">

        <!-- Header dùng chung với Home: hamburger + logo + search + giỏ hàng (có badge) -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/layoutHeader"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@color/color_background"
            android:elevation="2dp">
            <ImageView
                android:id="@+id/btnMenu"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginStart="12dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@null"
                android:padding="8dp"
                android:src="@drawable/ic_menu"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />
            <ImageView
                android:id="@+id/imgLogo"
                android:layout_width="wrap_content"
                android:layout_height="24dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Glassity"
                android:src="@drawable/logo_simplified"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="12dp"
                android:orientation="horizontal"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent">
                <ImageView
                    android:id="@+id/btnSearch"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@null"
                    android:padding="8dp"
                    android:src="@drawable/ic_search" />
                <!-- Giỏ hàng + badge số lượng -->
                <FrameLayout
                    android:layout_width="40dp"
                    android:layout_height="40dp">

                    <ImageView
                        android:id="@+id/btnCart"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:contentDescription="@null"
                        android:padding="8dp"
                        android:src="@drawable/ic_nav_cart"
                        app:tint="@color/color_text_primary" />

                    <TextView
                        android:id="@+id/tvCartBadge"
                        android:layout_width="17dp"
                        android:layout_height="17dp"
                        android:layout_gravity="top|end"
                        android:layout_marginTop="3dp"
                        android:layout_marginEnd="1dp"
                        android:background="@drawable/bg_dot_red"
                        android:gravity="center"
                        android:textColor="@color/white"
                        android:textSize="9sp"
                        android:textStyle="bold"
                        android:visibility="gone" />
                </FrameLayout>
            </LinearLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Thẻ thành viên: Glassity + barcode + số thẻ | điểm -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardMember"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            app:cardBackgroundColor="@color/white"
            app:cardCornerRadius="8dp"
            app:cardElevation="2dp"
            app:strokeColor="@color/color_divider"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_horizontal"
                android:orientation="vertical"
                android:padding="16dp">

                <ImageView
                    android:layout_width="wrap_content"
                    android:layout_height="28dp"
                    android:contentDescription="Glassity"
                    android:src="@drawable/logo_simplified" />

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="12dp"
                    android:contentDescription="Mã thành viên"
                    android:scaleType="fitCenter"
                    android:src="@drawable/img_barcode" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tvMemberCode"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="7253 20774 ⧉"
                        android:textColor="@color/color_text_primary"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginHorizontal="8dp"
                        android:text="|"
                        android:textColor="@color/color_divider" />

                    <TextView
                        android:id="@+id/tvPoints"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="1024 điểm"
                        android:textColor="@color/color_price"
                        android:textSize="14sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Khách: lớp trắng mờ đè lên barcode, mời đăng nhập/đăng ký -->
            <LinearLayout
                android:id="@+id/guestOverlay"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="#E6FFFFFF"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="16dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="Đăng ký / đăng nhập để sử dụng tích điểm"
                    android:textColor="@color/color_text_primary"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Grid tiện ích 2 cột -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp">

            <TextView
                android:id="@+id/menuOrders"
                style="@style/ProfileGridItem"
                android:text="📦  Đơn hàng của bạn" />

            <TextView
                android:id="@+id/menuPoints"
                style="@style/ProfileGridItem"
                android:text="🌟  Lịch sử tích điểm" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp">

            <TextView
                android:id="@+id/menuVouchers"
                style="@style/ProfileGridItem"
                android:text="🎫  Mã giảm giá" />

            <TextView
                android:id="@+id/menuAccount"
                style="@style/ProfileGridItem"
                android:text="👤  Thông tin tài khoản" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp">

            <TextView
                android:id="@+id/menuSettings"
                style="@style/ProfileGridItem"
                android:text="⚙️  Cài đặt" />

            <TextView
                android:id="@+id/menuFavorites"
                style="@style/ProfileGridItem"
                android:text="❤️  Sản phẩm yêu thích" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="8dp"
            android:layout_marginTop="12dp"
            android:background="@color/color_section_gap" />

        <!-- List hỗ trợ / chính sách -->
        <TextView android:id="@+id/rowSupport" style="@style/ProfileListRow"
            android:text="Liên hệ hỗ trợ" />
        <View style="@style/ProfileRowDivider" />

        <TextView android:id="@+id/rowFaq" style="@style/ProfileListRow"
            android:text="Câu hỏi thường gặp" />
        <View style="@style/ProfileRowDivider" />

        <TextView android:id="@+id/rowPrivacy" style="@style/ProfileListRow"
            android:text="Chính sách bảo mật" />
        <View style="@style/ProfileRowDivider" />

        <TextView android:id="@+id/rowWarranty" style="@style/ProfileListRow"
            android:text="Chính sách bảo hành" />
        <View style="@style/ProfileRowDivider" />

        <TextView android:id="@+id/rowShippingPolicy" style="@style/ProfileListRow"
            android:text="Chính sách Giao hàng và Kiểm tra sản phẩm" />
        <View style="@style/ProfileRowDivider" />

        <TextView
            android:id="@+id/btnLogout"
            style="@style/ProfileListRow"
            android:text="Đăng xuất"
            android:textColor="@color/color_accent"
            android:textStyle="bold" />

    </LinearLayout>
</ScrollView>
