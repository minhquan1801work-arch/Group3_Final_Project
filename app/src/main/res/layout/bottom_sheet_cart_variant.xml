<?xml version="1.0" encoding="utf-8"?>
<!-- DL_Choose product (Figma) — BottomSheet chỉnh variant + số lượng cho item trong Giỏ hàng -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/white"
    android:orientation="vertical">

    <!-- Ảnh + giá + kho -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp">

        <ImageView
            android:id="@+id/ivSheetProduct"
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:background="@drawable/bg_product_placeholder"
            android:contentDescription="@null"
            android:scaleType="centerCrop" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical"
            android:layout_marginStart="16dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvSheetPrice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/color_price"
                android:textSize="17sp"
                android:textStyle="bold"
                tools:text="449.000VND" />

            <TextView
                android:id="@+id/tvSheetStock"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="@color/color_text_secondary"
                android:textSize="12sp"
                tools:text="Kho: 32" />
        </LinearLayout>
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/color_divider" />

    <!-- Phân loại (chip màu) -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="12dp"
        android:text="Phân loại"
        android:textColor="@color/color_text_primary"
        android:textSize="13sp" />

    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="16dp"
        android:paddingVertical="10dp"
        android:scrollbars="none">

        <LinearLayout
            android:id="@+id/llSheetColors"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal" />
    </HorizontalScrollView>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/color_divider" />

    <!-- Số lượng -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="16dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Số lượng"
            android:textColor="@color/color_text_primary"
            android:textSize="13sp" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="26dp"
            android:background="@drawable/bg_qty_stepper"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/btnSheetMinus"
                android:layout_width="28dp"
                android:layout_height="match_parent"
                android:background="?attr/selectableItemBackground"
                android:contentDescription="@null"
                android:padding="7dp"
                android:src="@drawable/ic_minus" />

            <TextView
                android:id="@+id/tvSheetQty"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:minWidth="26dp"
                android:textColor="@color/color_text_primary"
                android:textSize="13sp"
                tools:text="1" />

            <ImageView
                android:id="@+id/btnSheetPlus"
                android:layout_width="28dp"
                android:layout_height="match_parent"
                android:background="?attr/selectableItemBackground"
                android:contentDescription="@null"
                android:padding="7dp"
                android:src="@drawable/ic_plus" />
        </LinearLayout>
    </LinearLayout>

    <!-- XÁC NHẬN -->
    <TextView
        android:id="@+id/btnSheetConfirm"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="@drawable/bg_btn_black_filled"
        android:gravity="center"
        android:text="XÁC NHẬN"
        android:textColor="@color/white"
        android:textSize="14sp"
        android:textStyle="bold" />

</LinearLayout>
