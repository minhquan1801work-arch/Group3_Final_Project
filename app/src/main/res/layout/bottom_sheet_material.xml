<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/color_background"
    android:orientation="vertical"
    android:paddingBottom="32dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="20dp"
        android:text="Chọn Gọng Kính (Kính Cận)"
        android:textColor="@color/color_text_primary"
        android:textSize="16sp"
        android:textStyle="bold" />

    <View
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:background="@color/color_field_border" />

    <TextView
        android:id="@+id/itemMatNhua"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:background="?attr/selectableItemBackground"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:text="Gọng Nhựa"
        android:textColor="@color/color_text_primary"
        android:textSize="15sp" />

    <TextView
        android:id="@+id/itemMatKimLoai"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:background="?attr/selectableItemBackground"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:text="Gọng Kim Loại"
        android:textColor="@color/color_text_primary"
        android:textSize="15sp" />

    <TextView
        android:id="@+id/itemMatClear"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:background="?attr/selectableItemBackground"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:text="Bỏ chọn"
        android:textColor="@color/color_text_secondary"
        android:textSize="15sp" />

</LinearLayout>
