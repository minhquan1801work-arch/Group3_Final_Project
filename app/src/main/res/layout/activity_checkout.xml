<?xml version="1.0" encoding="utf-8"?>
<!-- LA.Payment — màn Thanh toán theo Figma: nền trắng, kẻ mảnh, giá cam, nút đen -->
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    tools:context=".ui.order.CheckoutActivity">

    <!-- Toolbar -->
    <LinearLayout
        android:id="@+id/toolbar"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:background="@color/white"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@null"
            android:padding="12dp"
            android:src="@drawable/ic_arrow_back" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/checkout_title"
            android:textColor="@color/color_text_primary"
            android:textSize="15sp"
            android:textStyle="bold" />
    </LinearLayout>

    <View
        android:id="@+id/dividerToolbar"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:background="@color/color_divider"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toolbar" />

    <ScrollView
        android:id="@+id/nestedScroll"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toTopOf="@id/llBottomBar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/dividerToolbar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="16dp">

            <!-- ═══ 1. Địa chỉ nhận hàng ═══ -->
            <LinearLayout
                android:id="@+id/rowAddress"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="?attr/selectableItemBackground"
                android:orientation="horizontal"
                android:padding="12dp">

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_location"
                    app:tint="@color/color_price" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/checkout_address_title"
                        android:textColor="@color/color_text_primary"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvReceiver"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:textColor="@color/color_text_primary"
                        android:textSize="12sp"
                        tools:text="Lan Anh | (+84) 856 351 510" />

                    <TextView
                        android:id="@+id/tvAddress"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:textColor="@color/color_text_secondary"
                        android:textSize="12sp"
                        tools:text="C4/07, Tổ 17, Khu phố 3, Phường Long Bình, Đồng Nai" />

                    <TextView
                        android:id="@+id/tvAddressError"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="@string/checkout_address_required"
                        android:textColor="#D32F2F"
                        android:textSize="11sp"
                        android:visibility="gone" />
                </LinearLayout>

                <ImageView
                    android:id="@+id/btnEditAddress"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="center_vertical"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_chevron_right"
                    app:tint="@color/color_text_secondary" />
            </LinearLayout>

            <!-- Form địa chỉ cho KHÁCH (chưa đăng nhập) — nhập tay, không lưu sổ -->
            <LinearLayout
                android:id="@+id/layoutGuestAddress"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="12dp"
                android:paddingBottom="12dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/checkout_receiver_info_title"
                    android:textColor="@color/color_text_primary"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/etGuestName"
                    android:layout_width="match_parent"
                    android:layout_height="42dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_chip_variant"
                    android:hint="Họ tên người nhận *"
                    android:inputType="textPersonName"
                    android:paddingHorizontal="10dp"
                    android:textColor="@color/color_text_primary"
                    android:textColorHint="@color/color_hint"
                    android:textSize="13sp" />

                <EditText
                    android:id="@+id/etGuestPhone"
                    android:layout_width="match_parent"
                    android:layout_height="42dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_chip_variant"
                    android:hint="Số điện thoại *"
                    android:inputType="phone"
                    android:maxLength="10"
                    android:paddingHorizontal="10dp"
                    android:textColor="@color/color_text_primary"
                    android:textColorHint="@color/color_hint"
                    android:textSize="13sp" />

                <EditText
                    android:id="@+id/etGuestEmail"
                    android:layout_width="match_parent"
                    android:layout_height="42dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_chip_variant"
                    android:hint="Email *"
                    android:inputType="textEmailAddress"
                    android:paddingHorizontal="10dp"
                    android:textColor="@color/color_text_primary"
                    android:textColorHint="@color/color_hint"
                    android:textSize="13sp" />

                <!-- Tỉnh/Thành phố — dropdown -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilGuestProvince"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:hint="Tỉnh/Thành phố *"
                    app:boxStrokeColor="@color/brand_dark"
                    app:hintTextColor="@color/color_text_secondary">

                    <AutoCompleteTextView
                        android:id="@+id/actGuestProvince"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="none"
                        android:textColor="@color/color_text_primary"
                        android:textSize="13sp" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Quận/Huyện — dropdown, disabled cho đến khi chọn Tỉnh -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilGuestDistrict"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:hint="Quận/Huyện *"
                    app:boxStrokeColor="@color/brand_dark"
                    app:hintTextColor="@color/color_text_secondary">

                    <AutoCompleteTextView
                        android:id="@+id/actGuestDistrict"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="none"
                        android:textColor="@color/color_text_primary"
                        android:textSize="13sp" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Phường/Xã — dropdown, disabled cho đến khi chọn Huyện -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilGuestWard"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:hint="Phường/Xã *"
                    app:boxStrokeColor="@color/brand_dark"
                    app:hintTextColor="@color/color_text_secondary">

                    <AutoCompleteTextView
                        android:id="@+id/actGuestWard"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="none"
                        android:textColor="@color/color_text_primary"
                        android:textSize="13sp" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Số nhà / địa chỉ chi tiết -->
                <EditText
                    android:id="@+id/etGuestDetail"
                    android:layout_width="match_parent"
                    android:layout_height="42dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_chip_variant"
                    android:hint="Số nhà, tên đường... *"
                    android:inputType="textPostalAddress"
                    android:paddingHorizontal="10dp"
                    android:textColor="@color/color_text_primary"
                    android:textColorHint="@color/color_hint"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/tvGuestAddressError"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/err_guest_form_incomplete"
                    android:textColor="#D32F2F"
                    android:textSize="11sp"
                    android:visibility="gone" />
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="6dp" android:background="@color/color_section_gap" />

            <!-- ═══ 2. Sản phẩm ═══ -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="12dp"
                android:paddingTop="12dp"
                android:text="@string/checkout_products_label"
                android:textColor="@color/color_text_primary"
                android:textSize="13sp"
                android:textStyle="bold" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvProducts"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                tools:itemCount="1"
                tools:listitem="@layout/item_checkout_product" />

            <!-- Gray gap trước ô vận chuyển -->
            <View android:layout_width="match_parent" android:layout_height="6dp" android:background="@color/color_section_gap" />

            <!-- Phương thức vận chuyển — section riêng -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="12dp"
                android:paddingTop="12dp"
                android:paddingBottom="4dp"
                android:text="@string/checkout_shipping_title"
                android:textColor="@color/color_text_primary"
                android:textSize="13sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="12dp"
                android:layout_marginTop="4dp"
                android:orientation="vertical">

                <!-- Giao hàng tiêu chuẩn -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="4dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <RadioButton
                            android:id="@+id/rbShipStandard"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:buttonTint="@color/color_btn_black"
                            android:checked="true"
                            android:text="@string/checkout_ship_saving"
                            android:textColor="@color/color_text_primary"
                            android:textSize="13sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="36dp"
                            android:text="@string/checkout_ship_standard_days"
                            android:textColor="#9E9E9E"
                            android:textSize="11sp" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvShipStandardFee"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_vertical"
                        android:text="35.000đ"
                        android:textColor="@color/color_text_secondary"
                        android:textSize="12sp" />
                </LinearLayout>

                <!-- Divider xám -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/color_section_gap" />

                <!-- Giao hàng nhanh -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="4dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <RadioButton
                            android:id="@+id/rbShipFast"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:buttonTint="@color/color_btn_black"
                            android:text="@string/checkout_ship_fast"
                            android:textColor="@color/color_text_primary"
                            android:textSize="13sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="36dp"
                            android:text="@string/checkout_ship_fast_days"
                            android:textColor="#9E9E9E"
                            android:textSize="11sp" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvShipFastFee"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_vertical"
                        android:text="50.000đ"
                        android:textColor="@color/color_text_secondary"
                        android:textSize="12sp" />
                </LinearLayout>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="6dp" android:layout_marginTop="6dp" android:background="@color/color_section_gap" />

            <!-- ═══ 3. Mã giảm giá (1 row, chọn được cả discount + ship) ═══ -->
            <LinearLayout
                android:id="@+id/rowVoucher"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="?attr/selectableItemBackground"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="12dp">

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_voucher"
                    app:tint="@color/color_voucher_yellow" />

                <TextView
                    android:id="@+id/tvVoucherRowTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:text="@string/checkout_voucher_screen_title"
                    android:textColor="@color/color_text_primary"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvVoucherValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/color_price"
                    android:textSize="12sp"
                    tools:text="-100.000đ · Miễn phí VC" />

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:layout_marginStart="4dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_chevron_right"
                    app:tint="@color/color_text_secondary" />
            </LinearLayout>

            <!-- KHÁCH: gap + label tách "nhập mã" thành block riêng (gone mặc định) -->
            <View
                android:id="@+id/gapVoucherGuest"
                android:layout_width="match_parent"
                android:layout_height="6dp"
                android:background="@color/color_section_gap"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tvGuestVoucherLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="12dp"
                android:paddingTop="12dp"
                android:paddingBottom="4dp"
                android:text="@string/checkout_voucher_input_existing_hint"
                android:textColor="@color/color_text_primary"
                android:textSize="13sp"
                android:textStyle="bold"
                android:visibility="gone" />

            <!-- Nhập mã trực tiếp (Figma: "Nhập mã giảm giá...") -->
            <LinearLayout
                android:id="@+id/layoutVoucherInline"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="12dp"
                android:paddingBottom="10dp">

                <EditText
                    android:id="@+id/etVoucher"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_chip_variant"
                    android:hint="@string/checkout_voucher_input_hint"
                    android:imeOptions="actionDone"
                    android:inputType="textCapCharacters"
                    android:paddingHorizontal="10dp"
                    android:textColor="@color/color_text_primary"
                    android:textColorHint="@color/color_hint"
                    android:textSize="13sp" />

                <Button
                    android:id="@+id/btnApplyVoucherInline"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_btn_black_filled"
                    android:minWidth="0dp"
                    android:paddingHorizontal="16dp"
                    android:text="@string/checkout_voucher_apply"
                    android:textColor="@color/white"
                    android:textSize="12sp" />
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="6dp" android:background="@color/color_section_gap" />

            <!-- ═══ 4. Phương thức thanh toán ═══ -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="12dp"
                android:paddingTop="12dp"
                android:text="@string/checkout_payment_title"
                android:textColor="@color/color_text_primary"
                android:textSize="13sp"
                android:textStyle="bold" />

            <!-- Điểm thành viên toggle (Figma: nền viền nhạt như các ô khác) -->
            <LinearLayout
                android:id="@+id/layoutPointsSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="12dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_chip_variant"
                android:orientation="vertical"
                android:paddingHorizontal="10dp"
                android:paddingVertical="10dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_star"
                        app:tint="@color/color_price" />

                    <TextView
                        android:id="@+id/tvPointsLabel"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        android:text="@string/checkout_points_label"
                        android:textColor="@color/color_text_primary"
                        android:textSize="13sp" />

                    <androidx.appcompat.widget.SwitchCompat
                        android:id="@+id/swUsePoints"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="false" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tvPointsError"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/checkout_no_points_msg"
                    android:textColor="#D32F2F"
                    android:textSize="11sp"
                    android:visibility="gone" />

                <!-- Hiện khi switch bật -->
                <LinearLayout
                    android:id="@+id/rowPointsInfo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:visibility="gone"
                    tools:visibility="visible">

                    <TextView
                        android:id="@+id/tvPointsBalance"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textColor="@color/color_text_secondary"
                        android:textSize="12sp"
                        tools:text="Số điểm: 1024 điểm" />

                    <TextView
                        android:id="@+id/tvPointsDiscountAmount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/color_price"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        tools:text="-1.024đ" />
                </LinearLayout>
            </LinearLayout>

            <!-- COD -->
            <RadioButton
                android:id="@+id/rbCod"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="12dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_chip_variant"
                android:buttonTint="@color/color_btn_black"
                android:checked="true"
                android:paddingHorizontal="8dp"
                android:paddingVertical="10dp"
                android:text="@string/checkout_pay_cod"
                android:textColor="@color/color_text_primary"
                android:textSize="13sp" />

            <!-- Bank Transfer -->
            <RadioButton
                android:id="@+id/rbBank"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="12dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_chip_variant"
                android:buttonTint="@color/color_btn_black"
                android:paddingHorizontal="8dp"
                android:paddingVertical="10dp"
                android:text="@string/checkout_pay_bank"
                android:textColor="@color/color_text_primary"
                android:textSize="13sp" />

            <!-- Ví điện tử -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="12dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_chip_variant"
                android:orientation="vertical"
                android:paddingVertical="4dp">

                <RadioButton
                    android:id="@+id/rbWallet"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:buttonTint="@color/color_btn_black"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="8dp"
                    android:text="@string/checkout_pay_wallet"
                    android:textColor="@color/color_text_primary"
                    android:textSize="13sp" />

                <!-- Logo ví điện tử (Figma: Momo, ZaloPay, VNPAY) -->
                <LinearLayout
                    android:id="@+id/layoutWalletLogos"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingHorizontal="8dp"
                    android:paddingBottom="8dp"
                    android:visibility="gone"
                    tools:visibility="visible">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="28dp"
                        android:layout_marginEnd="8dp"
                        android:background="#E61F5C"
                        android:gravity="center"
                        android:paddingHorizontal="10dp"
                        android:text="Momo"
                        android:textColor="@color/white"
                        android:textSize="11sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="28dp"
                        android:layout_marginEnd="8dp"
                        android:background="#0068FF"
                        android:gravity="center"
                        android:paddingHorizontal="10dp"
                        android:text="ZaloPay"
                        android:textColor="@color/white"
                        android:textSize="11sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="28dp"
                        android:background="#00509D"
                        android:gravity="center"
                        android:paddingHorizontal="10dp"
                        android:text="VNPAY"
                        android:textColor="@color/white"
                        android:textSize="11sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="6dp" android:layout_marginTop="12dp" android:background="@color/color_section_gap" />

            <!-- ═══ 5. Chi tiết thanh toán ═══ -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="12dp"
                android:paddingTop="12dp"
                android:text="@string/checkout_summary_title"
                android:textColor="@color/color_text_primary"
                android:textSize="13sp"
                android:textStyle="bold" />

            <!-- Tổng tiền hàng -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="12dp"
                android:paddingTop="8dp">

                <TextView
                    android:id="@+id/tvSubtotalLabel"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/checkout_summary_subtotal"
                    android:textColor="@color/color_text_secondary"
                    android:textSize="12sp"
                    tools:text="Tổng tiền hàng (1 sản phẩm)" />

                <TextView
                    android:id="@+id/tvSubtotal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/color_text_primary"
                    android:textSize="12sp"
                    tools:text="449.000đ" />
            </LinearLayout>

            <!-- Điểm thưởng (phần thưởng khi mua hàng) -->
            <LinearLayout
                android:id="@+id/rowRewardPoints"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="12dp"
                android:paddingTop="4dp"
                android:visibility="gone"
                tools:visibility="visible">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/checkout_summary_reward_points"
                    android:textColor="@color/color_text_secondary"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/tvRewardPoints"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#4CAF50"
                    android:textSize="12sp"
                    tools:text="+449" />
            </LinearLayout>

            <!-- Phí vận chuyển -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="12dp"
                android:paddingTop="4dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/checkout_summary_shipping"
                    android:textColor="@color/color_text_secondary"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/tvShippingFee"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/color_text_primary"
                    android:textSize="12sp"
                    tools:text="35.000đ" />
            </LinearLayout>

            <!-- Giảm ship (khi dùng FREESHIP) -->
            <LinearLayout
                android:id="@+id/rowShipDiscount"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="12dp"
                android:paddingTop="4dp"
                android:visibility="gone"
                tools:visibility="visible">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/checkout_summary_ship_discount"
                    android:textColor="@color/color_text_secondary"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/tvShipDiscount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/color_price"
                    android:textSize="12sp"
                    tools:text="-35.000đ" />
            </LinearLayout>

            <!-- Giảm giá voucher -->
            <LinearLayout
                android:id="@+id/rowVoucherDiscount"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="12dp"
                android:paddingTop="4dp"
                android:visibility="gone"
                tools:visibility="visible">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/checkout_summary_discount"
                    android:textColor="@color/color_text_secondary"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/tvDiscount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/color_price"
                    android:textSize="12sp"
                    tools:text="-52.480đ" />
            </LinearLayout>

            <!-- Giảm từ điểm thành viên (khi bật toggle) -->
            <LinearLayout
                android:id="@+id/rowPointsDiscount"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="12dp"
                android:paddingTop="4dp"
                android:visibility="gone"
                tools:visibility="visible">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/checkout_summary_points_discount"
                    android:textColor="@color/color_text_secondary"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/tvPointsDiscountSummary"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/color_price"
                    android:textSize="12sp"
                    tools:text="-1.024đ" />
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp" android:layout_marginHorizontal="12dp" android:layout_marginTop="8dp" android:background="@color/color_divider" />

            <!-- Tổng thanh toán -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="12dp"
                android:paddingVertical="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/checkout_summary_total"
                    android:textColor="@color/color_text_primary"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvGrandTotal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/color_price"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    tools:text="376.520đ" />
            </LinearLayout>

            <!-- Logo ngân hàng / cổng thanh toán được chấp nhận (trust signal) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:background="@color/color_section_gap"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="12dp"
                android:paddingVertical="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="24dp"
                    android:layout_marginEnd="6dp"
                    android:background="#215A0D"
                    android:gravity="center"
                    android:paddingHorizontal="7dp"
                    android:text="VCB"
                    android:textColor="@color/white"
                    android:textSize="10sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="24dp"
                    android:layout_marginEnd="6dp"
                    android:background="#1E3A8A"
                    android:gravity="center"
                    android:paddingHorizontal="7dp"
                    android:text="CTG"
                    android:textColor="@color/white"
                    android:textSize="10sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="24dp"
                    android:layout_marginEnd="6dp"
                    android:background="#8B0000"
                    android:gravity="center"
                    android:paddingHorizontal="7dp"
                    android:text="AGR"
                    android:textColor="@color/white"
                    android:textSize="10sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="24dp"
                    android:layout_marginEnd="6dp"
                    android:background="#005BAC"
                    android:gravity="center"
                    android:paddingHorizontal="7dp"
                    android:text="BIDV"
                    android:textColor="@color/white"
                    android:textSize="10sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="24dp"
                    android:layout_marginEnd="6dp"
                    android:background="#CC1F3A"
                    android:gravity="center"
                    android:paddingHorizontal="7dp"
                    android:text="MB"
                    android:textColor="@color/white"
                    android:textSize="10sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="24dp"
                    android:gravity="center"
                    android:paddingHorizontal="7dp"
                    android:text="+44"
                    android:textColor="@color/color_text_secondary"
                    android:textSize="10sp" />
            </LinearLayout>

            <!-- Footnote điều khoản (Figma) — "Điều khoản Glassity" clickable -->
            <TextView
                android:id="@+id/tvTermsNote"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="12dp"
                android:paddingVertical="8dp"
                android:text="@string/checkout_terms_note"
                android:textColor="@color/color_hint"
                android:textSize="11sp" />

        </LinearLayout>
    </ScrollView>

    <!-- Thanh dưới: "Tổng cộng: xxx" cam + ĐẶT HÀNG đen -->
    <LinearLayout
        android:id="@+id/llBottomBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@color/white"
        android:elevation="8dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingEnd="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/checkout_total_label"
            android:textColor="@color/color_text_secondary"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/tvBottomTotal"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:layout_weight="1"
            android:textColor="@color/color_price"
            android:textSize="15sp"
            android:textStyle="bold"
            tools:text="376.520đ" />

        <Button
            android:id="@+id/btnPlaceOrder"
            android:layout_width="wrap_content"
            android:layout_height="52dp"
            android:background="@drawable/bg_btn_black_filled"
            android:paddingHorizontal="24dp"
            android:text="@string/checkout_place_order"
            android:textColor="@color/white"
            android:textSize="13sp"
            android:textStyle="bold" />
    </LinearLayout>

    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:indeterminateTint="@color/color_btn_black"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
