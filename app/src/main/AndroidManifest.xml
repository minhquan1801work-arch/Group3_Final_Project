<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Group3_Final_Project">

        <!-- Màn khởi động: chọn Đăng nhập / Đăng ký / Khách -->
        <activity
            android:name=".ui.account.WelcomeActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".ui.account.LoginActivity"
            android:exported="false" />

        <activity
            android:name=".ui.account.SignupActivity"
            android:exported="false" />

        <activity
            android:name=".ui.account.ForgotPasswordActivity"
            android:exported="false" />

        <!-- MainActivity không còn là màn khởi động — chỉ mở SAU khi đăng nhập/đăng ký/khách thành công -->
        <activity
            android:name=".MainActivity"
            android:exported="false" />

        <activity
            android:name=".ui.catalog.ProductListActivity"
            android:exported="false" />

        <activity
            android:name=".ui.catalog.SearchActivity"
            android:exported="false"
            android:windowSoftInputMode="stateVisible" />

        <activity
            android:name=".ui.catalog.CollectionActivity"
            android:exported="false" />

        <!-- [B1] Chi tiết sản phẩm (DL_Product Detail_Layout2) -->
        <activity
            android:name=".ui.catalog.ProductDetailActivity"
            android:exported="false" />

        <!-- Person A — luồng Giỏ hàng → Thanh toán -->
        <activity
            android:name=".ui.order.CheckoutActivity"
            android:exported="false" />

        <activity
            android:name=".ui.order.PaymentResultActivity"
            android:exported="false" />

        <!-- Sổ địa chỉ (LA.Address) + Thêm/Sửa địa chỉ (DL_Add New Address) -->
        <activity
            android:name=".ui.order.AddressListActivity"
            android:exported="false" />

        <activity
            android:name=".ui.order.AddAddressActivity"
            android:exported="false" />

        <!-- Kho mã giảm giá (LA.Voucher) -->
        <activity
            android:name=".ui.account.VoucherActivity"
            android:exported="false" />

        <!-- Chọn mã giảm giá trong Checkout (LA.Voucher3) -->
        <activity
            android:name=".ui.order.CheckoutVoucherActivity"
            android:exported="false" />

        <!-- Account sub-screens -->
        <activity
            android:name=".ui.account.AccountInfoActivity"
            android:exported="false" />

        <activity
            android:name=".ui.order.OrderHistoryActivity"
            android:exported="false" />

        <activity
            android:name=".ui.order.OrderDetailActivity"
            android:exported="false" />

        <activity
            android:name=".ui.order.ReviewActivity"
            android:exported="false" />

        <activity
            android:name=".ui.account.ContactActivity"
            android:exported="false" />

        <activity
            android:name=".ui.account.PointHistoryActivity"
            android:exported="false" />

        <activity
            android:name=".ui.account.SettingsActivity"
            android:exported="false" />

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>
    </application>

</manifest>